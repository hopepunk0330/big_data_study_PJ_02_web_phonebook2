# 프로젝트 루트 .env 템플릿 — 실제 값을 채운 .env를 이 옆에 만들어 사용한다.
# .env는 .gitignore에 등록되어 있어 커밋되지 않는다.

# docker-compose.yml의 pg-lab(PostgreSQL 16) 컨테이너 비밀번호
POSTGRES_PASSWORD=changeme

# backend/database.py가 읽는 DB 접속 문자열
# 형식: postgresql+psycopg://{user}:{password}@{host}:{port}/{db}
DATABASE_URL=postgresql+psycopg://contact_app:changeme@localhost:5432/contact_app
